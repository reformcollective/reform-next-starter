{
	"name": "website",
	"private": true,
	"author": "Reform Collective",
	"type": "module",
	"scripts": {
		"dev": "wireit",
		"build": "wireit",
		"serve": "wireit",
		"test": "wireit",
		"lint": "wireit",
		"format": "wireit",
		"pnpm:devPreinstall": "pnpm init-submodule && pnpm git-config",
		"postinstall": "pnpm check-env",
		"prepare": "lefthook install",
		"check-env": "if [ -n \"$CI\" ]; then exit 0; else node --env-file=.env app/env.ts || (pnpm dlx cowsay 'You are missing a .env file' && exit 1); fi",
		"git-config": "git config submodule.recurse true",
		"init-submodule": "git diff --exit-code --quiet && git submodule update --init || exit 0"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@capsizecss/core": "^4.1.3",
		"@sanity/assist": "^6.1.3",
		"@sanity/client": "^7.23.0",
		"@sanity/code-input": "^7.1.6",
		"@sanity/icons": "^3.7.4",
		"@sanity/vision": "^6.1.0",
		"@svgr/webpack": "^8.1.0",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@total-typescript/ts-reset": "^0.6.1",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260622.1",
		"@userback/widget": "^0.3.12",
		"@vanilla-extract/css": "^1.20.1",
		"ahooks": "^3.9.7",
		"babel-plugin-react-compiler": "^1.0.0",
		"gsap": "^3.15.0",
		"lefthook": "^2.1.9",
		"next": "^16.2.9",
		"next-sanity": "^13.1.1",
		"nuqs": "^2.8.9",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"sanity": "^6.1.0",
		"sanity-plugin-asset-source-unsplash": "^7.0.10",
		"sanity-plugin-link-field": "file:library/vendor/sanity-plugin-link-field-1.6-preview.tgz",
		"sanity-plugin-media": "^5.0.2",
		"sanity-plugin-mux-input": "^4.0.2",
		"server-only": "^0.0.1",
		"stylelint": "^17.13.0",
		"svgo": "^4.0.1",
		"typescript": "^6.0.3",
		"unlighthouse": "^0.17.10",
		"vite-tsconfig-paths": "^6.1.1",
		"wireit": "^0.14.12",
		"zod": "^4.4.3"
	},
	"devDependencies": {},
	"stylelint": {
		"extends": "./library/config/stylelint.config.js"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.17.0",
			"onFail": "download"
		}
	},
	"packageManager": "pnpm@11.8.0",
	"wireit": {
		"dev": {
			"command": "next dev",
			"dependencies": [
				"typegen:dev"
			],
			"service": true
		},
		"serve": {
			"command": "next start",
			"dependencies": [
				"build"
			],
			"service": true
		},
		"build-next": {
			"command": "next build"
		},
		"build": {
			"dependencies": [
				"build-next",
				"generate-manifest"
			]
		},
		"generate-manifest": {
			"command": "mkdir -p public/studio && sanity manifest extract --path public/studio/static",
			"files": [
				".env",
				"app/env.ts",
				"library/**/*.ts",
				"library/**/*.tsx",
				"sanity/**/*",
				"sanity.config.ts",
				"sanity.cli.ts",
				"tsconfig.json"
			],
			"output": [
				"public/studio/static/**/*"
			]
		},
		"sanity-schema:dev": {
			"command": "sanity schema extract --watch",
			"service": true
		},
		"typegen:dev": {
			"command": "sanity typegen generate --watch",
			"dependencies": [
				"sanity-schema:dev"
			],
			"service": true
		},
		"sanity-typegen:check": {
			"command": "(sanity schema extract && sanity typegen generate) || (pnpm exec sanity schema validate)",
			"files": [
				".env",
				"sanity/**/*",
				"sanity.config.ts",
				"sanity.cli.ts",
				"tsconfig.json",
				"app/**/*.ts",
				"app/**/*.tsx",
				"app/**/*.js",
				"app/**/*.jsx",
				"library/**/*.ts",
				"library/**/*.tsx",
				"library/**/*.js",
				"library/**/*.jsx"
			],
			"output": [
				"schema.json",
				"sanity.types.ts"
			]
		},
		"next-typegen:check": {
			"command": "next typegen",
			"files": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"library/siteURL/**/*.ts",
				"library/vanilla/**/*.ts",
				"next.config.ts",
				"tsconfig.json"
			],
			"output": [
				".next/types/**/*.ts",
				"next-env.d.ts"
			]
		},
		"typegen:check": {
			"dependencies": [
				"next-typegen:check",
				"sanity-typegen:check"
			]
		},
		"stylelint": {
			"command": "stylelint . --fix"
		},
		"oxlint": {
			"command": "oxlint --fix",
			"dependencies": [
				"typegen:check"
			]
		},
		"lint": {
			"dependencies": [
				"./library:lint",
				"stylelint",
				"oxlint"
			]
		},
		"oxfmt": {
			"command": "oxfmt"
		},
		"format": {
			"dependencies": [
				"./library:format",
				"oxfmt"
			]
		},
		"test": {
			"dependencies": [
				"./library:test"
			]
		}
	}
}
