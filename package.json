{
	"name": "website",
	"private": true,
	"author": "Reform Collective",
	"type": "module",
	"scripts": {
		"dev": "wireit",
		"build": "wireit",
		"serve": "wireit",
		"test": "wireit",
		"lint": "wireit",
		"format": "wireit",
		"typegen": "wireit",
		"typecheck": "wireit",
		"generate-manifest": "wireit",
		"pnpm:devPreinstall": "pnpm init-submodule && pnpm git-config",
		"postinstall": "pnpm check-env",
		"prepare": "lefthook install",
		"check-env": "if [ -n \"$CI\" ]; then exit 0; else node --env-file=.env app/env.ts || (pnpm dlx cowsay 'You are missing a .env file' && exit 1); fi",
		"git-config": "git config submodule.recurse true",
		"init-submodule": "git diff --exit-code --quiet && git submodule update --init || exit 0"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@capsizecss/core": "^4.1.3",
		"@sanity/assist": "^5.0.4",
		"@sanity/client": "^7.22.0",
		"@sanity/code-input": "^7.1.0",
		"@sanity/icons": "^3.7.4",
		"@sanity/image-url": "^2.1.1",
		"@sanity/vision": "^5.25.0",
		"@svgr/webpack": "^8.1.0",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@total-typescript/ts-reset": "^0.6.1",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^25.7.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260513.1",
		"@userback/widget": "^0.3.12",
		"@vanilla-extract/css": "^1.20.1",
		"@vanilla-extract/dynamic": "^2.1.5",
		"ahooks": "^3.9.7",
		"babel-plugin-react-compiler": "^1.0.0",
		"gsap": "^3.15.0",
		"lefthook": "^2.1.6",
		"lenis": "^1.3.23",
		"next": "^16.2.6",
		"next-sanity": "13.0.0-cache-components.57",
		"nuqs": "^2.8.9",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.64.0",
		"oxlint-tsgolint": "^0.20.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-player": "^3.4.0",
		"sanity": "^5.25.0",
		"sanity-plugin-asset-source-unsplash": "^7.0.5",
		"sanity-plugin-link-field": "^1.5.1",
		"sanity-plugin-media": "^4.3.0",
		"sanity-plugin-mux-input": "^2.19.0",
		"server-only": "^0.0.1",
		"stylelint": "^17.11.0",
		"svgo": "^4.0.1",
		"typescript": "^5.9.3",
		"unlighthouse": "^0.17.9",
		"vite-tsconfig-paths": "^6.1.1",
		"wireit": "^0.14.12",
		"zod": "^4.4.3"
	},
	"devDependencies": {},
	"stylelint": {
		"extends": "./library/config/stylelint.config.js"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.15.0",
			"onFail": "download"
		}
	},
	"packageManager": "pnpm@11.0.3",
	"wireit": {
		"dev": {
			"command": "next dev",
			"dependencies": [
				"typegen"
			],
			"service": true
		},
		"serve": {
			"command": "next start",
			"dependencies": [
				"build"
			],
			"service": true
		},
		"build-next": {
			"command": "next build"
		},
		"build": {
			"dependencies": [
				"build-next",
				"typecheck",
				"generate-manifest"
			]
		},
		"typecheck": {
			"command": "tsgo",
			"dependencies": [
				"typegen"
			]
		},
		"generate-manifest": {
			"command": "mkdir -p public/studio && sanity manifest extract --path public/studio/static",
			"files": [
				"sanity/**/*",
				"sanity.config.ts"
			],
			"output": [
				"public/studio/static/**/*"
			]
		},
		"sanity-typegen": {
			"command": "(sanity schema extract && sanity typegen generate) || (pnpm exec sanity schema validate)",
			"files": [
				"sanity/**/*",
				"sanity.config.ts",
				"app/**/*.ts",
				"app/**/*.tsx",
				"library/**/*.ts",
				"library/**/*.tsx",
				"sanity.cli.ts"
			],
			"output": [
				"schema.json",
				"sanity.types.ts"
			]
		},
		"next-typegen": {
			"command": "next typegen",
			"files": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"next.config.ts",
				"tsconfig.json"
			],
			"output": [
				".next/types/**/*.ts"
			]
		},
		"typegen": {
			"dependencies": [
				"next-typegen",
				"sanity-typegen"
			]
		},
		"stylelint": {
			"command": "stylelint . --fix"
		},
		"oxlint": {
			"command": "oxlint --fix",
			"dependencies": [
				"typegen"
			]
		},
		"lint": {
			"dependencies": [
				"./library:lint",
				"stylelint",
				"oxlint"
			]
		},
		"oxfmt": {
			"command": "oxfmt"
		},
		"format": {
			"dependencies": [
				"./library:format",
				"oxfmt"
			]
		},
		"test": {
			"dependencies": [
				"./library:test"
			]
		}
	}
}
