{
	"extends": "@total-typescript/tsconfig/bundler/dom",
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"*": ["./*"],
			"page": ["./app/[[...slug]]/page"],
			"images/*": ["./app/images/*"],
			"library/*": ["./library/*"],
			"styles/*": ["./app/styles/*"],
			"components/*": ["./app/components/*"],
			"sections/*": ["./app/sections/*"],
			"utils/*": ["./app/utils/*"],
			"types/*": ["./app/types/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts", "**/*.mts"],
	"exclude": ["next-env.d.ts", "node_modules"]
}
